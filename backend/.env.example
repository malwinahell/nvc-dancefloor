# Skopiuj jako .env i uzupełnij realnymi wartościami z Supabase Dashboard
# (Project Settings → API).

SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
# Project Settings → API → JWT Secret (NIE service_role key)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Hasło bramki wejściowej do aplikacji
GATE_PASSWORD=kochamnvc
# Dowolny losowy, długi string — np. `openssl rand -hex 32`
GATE_JWT_SECRET=generate-a-long-random-secret
GATE_COOKIE_NAME=nvc_gate
GATE_TOKEN_TTL_DAYS=30

FRONTEND_ORIGIN=http://localhost:3000
ENVIRONMENT=development
